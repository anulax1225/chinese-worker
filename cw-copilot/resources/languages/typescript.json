{
  "id": "typescript",
  "extensions": [".ts", ".tsx"],
  "commentPrefix": "//",
  "stopSequences": [
    "\n\n",
    "\nfunction ",
    "\nclass ",
    "\nexport ",
    "\nconst ",
    "\nimport ",
    "\ninterface ",
    "\ntype ",
    "\nenum "
  ],
  "topLevelNodes": [
    "class_declaration",
    "function_declaration",
    "lexical_declaration",
    "interface_declaration",
    "type_alias_declaration",
    "enum_declaration",
    "export_statement"
  ],
  "importPatterns": ["^import\\s", "^export\\s+\\{"],
  "nodeStopPatterns": {
    "class_declaration": ["\nclass "],
    "function_declaration": ["\nfunction "],
    "lexical_declaration": ["\nconst ", "\nlet ", "\nvar "],
    "interface_declaration": ["\ninterface "],
    "type_alias_declaration": ["\ntype "],
    "enum_declaration": ["\nenum "],
    "export_statement": ["\nexport "]
  }
}
