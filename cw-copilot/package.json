{
  "name": "cw-copilot",
  "displayName": "cw-copilot",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "CW Copilot",
      "properties": {
        "cw.apiUrl": {
          "type": "string",
          "default": "http://localhost",
          "description": "Base URL of your Chinese Worker instance"
        },
        "cw.apiToken": {
          "type": "string",
          "default": "",
          "description": "Sanctum API bearer token"
        },
        "cw.agentId": {
          "type": "number",
          "default": 1,
          "description": "Agent ID to use for completions"
        },
        "cw.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline completions"
        },
        "cw.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Delay in ms before triggering completion"
        },
        "cw.maxPrefixLines": {
          "type": "number",
          "default": 100,
          "description": "Maximum lines before cursor sent as prompt"
        },
        "cw.maxSuffixLines": {
          "type": "number",
          "default": 30,
          "description": "Maximum lines after cursor sent as suffix"
        },
        "cw.maxTokens": {
          "type": "number",
          "default": 100,
          "description": "Maximum tokens for the completion response"
        },
        "cw.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Sampling temperature (0-2)"
        },
        "cw.enableFIM": {
          "type": "boolean",
          "default": false,
          "description": "Send suffix for fill-in-the-middle (requires FIM-capable model)"
        },
        "cw.fimTokenFamily": {
          "type": "string",
          "default": "",
          "description": "FIM token family (qwen, codellama, starcoder, deepseek, codestral, codegemma, devstral). See .cw/fim-tokens.json."
        },
        "cw.thinkingModel": {
          "type": "boolean",
          "default": false,
          "description": "Strip <think> blocks from response (for thinking models like lfm2.5-thinking)"
        }
      }
    },
    "commands": [
      {
        "command": "cw.toggle",
        "title": "CW Copilot: Toggle"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
